# Email service (Resend — https://resend.com)
# Required for the contact form to send emails.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# The "from" address shown in outgoing emails.
# Must be a verified domain in your Resend account.
RESEND_FROM_EMAIL=Contact <hello@yourdomain.com>

# The inbox where contact form submissions are delivered.
RESEND_TO_EMAIL=hello@yourdomain.com

# Bundle analyser — set to "true" to open a visual bundle report after build.
# ANALYZE=false
